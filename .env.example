NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Deployment URLs — REQUIRED for production
# BASE_URL is used for Swagger docs, email links, etc.
BASE_URL=https://api.yourdomain.com
# Comma-separated allowed origins (e.g. "https://app.yourdomain.com,https://admin.yourdomain.com")
CORS_ORIGIN=*

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance_app?schema=public"

JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

SUPER_ADMIN_PHONE=9999999999
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Finance App <no-reply@financeapp.com>"

FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Cloudinary — file storage for KYC documents & receipt PDFs.
# Create a free account at https://cloudinary.com, then copy the three
# credentials from the Cloudinary Dashboard > Programmable Media > API Keys.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMS_PROVIDER=none
SMS_API_KEY=
SMS_SENDER_ID=

UPI_ID=merchant@upi
UPI_PAYEE_NAME=Finance Company

# Optional: set these to enable real UPI collection via Razorpay instead of
# the static UPI-intent QR code. Leave blank to keep using manual confirmation.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

ENCRYPTION_KEY=change_this_32_char_encryption_key_
